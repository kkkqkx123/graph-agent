{
    "name": "@modular-agent/sdk",
    "version": "1.0.0",
    "description": "Modular Agent Framework SDK - Workflow execution engine",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc --watch",
        "test": "vitest run --reporter=verbose",
        "test:watch": "vitest --watch",
        "test:coverage": "vitest run --coverage",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist",
        "prebuild": "npm run clean"
    },
    "keywords": [
        "agent",
        "workflow",
        "llm",
        "sdk"
    ],
    "author": "Modular Agent Framework Team",
    "license": "MIT",
    "dependencies": {
        "@modular-agent/types": "workspace:*",
        "@modular-agent/common-utils": "workspace:*",
        "@modular-agent/tool-executors": "workspace:*",
        "@modular-agent/script-executors": "workspace:*",
        "tiktoken": "^1.0.22",
        "zod": "^4.3.6",
        "@iarna/toml": "^2.2.5",
        "async-mutex": "^0.5.0"
    },
    "devDependencies": {},
    "engines": {
        "node": ">=22.0.0"
    }
}