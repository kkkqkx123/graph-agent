{
  "name": "@modular-agent/cli-app",
  "version": "1.0.0",
  "description": "Modular Agent Framework CLI Application",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "modular-agent": "./scripts/modular-agent.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json"
  },
  "keywords": [
    "cli",
    "workflow",
    "agent",
    "modular-agent"
  ],
  "author": "Modular Agent Framework Team",
  "license": "MIT",
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@iarna/toml": "^2.2.5",
    "@modular-agent/common-utils": "workspace:*",
    "@modular-agent/sdk": "workspace:*",
    "@modular-agent/tool-executors": "workspace:*",
    "@modular-agent/types": "workspace:*",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.0",
    "fs-extra": "^11.3.3",
    "glob": "^13.0.6",
    "inquirer": "^13.2.5",
    "node-pty": "^1.1.0",
    "ora": "^9.3.0",
    "p-limit": "^7.3.0",
    "p-map": "^7.0.4",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}